$TTL 24h
$ORIGIN homelab.lan.
@           IN      SOA     ns1.homelab.lan. admin.homelab.lan. (
                                1               ; serial number
		                        24h			    ; refresh period
		                        2h			    ; retry period
		                        1000h			; expire time
		                        2d   			; negative TTL
                                )

@           IN      NS      ns1.homelab.lan.

ns1		    IN      A	    192.168.1.150

; Main VLAN network services
api         IN      A       192.168.1.151
gapi        IN      A       192.168.1.152
rpg         IN      A       192.168.1.153
site        IN      A       192.168.1.154
sigr        IN      A       192.168.1.155
elrakis     IN      A       192.168.1.156
ns1         IN      A       192.168.1.150
host        IN      A       192.168.1.150
