$TTL 24h
$ORIGIN 168.192.in-addr.arpa.
@           IN      SOA     ns1.homelab.lan. admin.homelab.lan. (
                                1               ; serial number
		                        24h			    ; refresh period
		                        2h			    ; retry period
		                        1000h			; expire time
		                        2d   			; negative TTL
                                )

            IN      NS      ns1.homelab.lan.

$ORIGIN 1.168.192.in-addr.arpa.
; Main VLAN network services
151         IN      PTR     api.homelab.lan.
152         IN      PTR     gapi.homelab.lan.
153         IN      PTR     rpg.homelab.lan.
154         IN      PTR     site.homelab.lan.
155         IN      PTR     sigr.homelab.lan.
156         IN      PTR     elrakis.homelab.lan.
150         IN      PTR     host.homelab.lan.
